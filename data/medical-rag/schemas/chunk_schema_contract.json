{
  "release_version": "0.1.0",
  "created_at": "2026-07-09",
  "schema_name": "golden_medical_rag_chunk_v0_1",
  "required_keys": [
    "chunk_id",
    "tome_id",
    "version",
    "language",
    "source_ids",
    "license_status",
    "clinical_status",
    "legal_status",
    "clinical_domain",
    "population",
    "severity_level",
    "red_flag_relevant",
    "clinical_action_type",
    "must_ask",
    "must_not_say",
    "safe_user_message",
    "internal_reasoning_summary",
    "evidence_summary",
    "retrieval_keywords",
    "created_at",
    "reviewed_at",
    "reviewers",
    "is_example_only",
    "production_allowed",
    "medical_review_status",
    "legal_review_status",
    "approval_evidence"
  ],
  "severity_enum": [
    "S1",
    "S2",
    "S3",
    "S4",
    "S5",
    "S6"
  ],
  "production_default": false,
  "validation_rules": [
    "chunk_id must be globally unique",
    "severity_level must be S1-S6",
    "source_ids must not be empty",
    "must_ask must not be empty",
    "must_not_say must not be empty",
    "production_allowed must remain false until signoff",
    "S5/S6 chunks must set red_flag_relevant=true",
    "pediatric or dosing chunks must fail closed when required data are missing",
    "regionalized chunks must not change clinical severity"
  ],
  "recommended_vector_metadata": [
    "chunk_id",
    "tome_id",
    "master_release_tome",
    "version",
    "language",
    "source_ids",
    "clinical_domain",
    "population",
    "severity_level",
    "red_flag_relevant",
    "clinical_action_type",
    "production_allowed",
    "medical_review_status",
    "legal_review_status",
    "created_at"
  ]
}