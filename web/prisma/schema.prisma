datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  name               String
  role               String         @default("paciente") // paciente, medico, admin, superadmin
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  doctorProfile      DoctorProfile?
  cases              ClinicalCase[]
  wallet             Wallet?
  appointments       Appointment[]  @relation("PatientAppointments")
  doctorAppointments Appointment[]  @relation("DoctorAppointments")
  auditLogs          AuditLog[]
}

model DoctorProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cedula             String?  @unique
  ineFront           String?
  ineBack            String?
  verificationStatus String   @default("pendiente") // pendiente, en_revision, activo, rechazado
  bankName           String?
  bankAccountName    String?
  clabe              String?
  schedule           Json?    // Almacena bloques de disponibilidad
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ClinicalCase {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  status       String        @default("en_analisis") // en_analisis, enfermo, derivado, en_tratamiento, curado, archivado
  timeline     Json          @default("[]") // Lista de eventos en formato JSON
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  messages     Message[]
  appointments Appointment[]
}

model Message {
  id           String       @id @default(uuid())
  caseId       String
  clinicalCase ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sender       String       // user, assistant
  content      String
  attachments  Json         @default("[]") // Lista de adjuntos en formato JSON
  createdAt    DateTime     @default(now())
}

model Appointment {
  id           String        @id @default(uuid())
  patientId    String
  patient      User          @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctorId     String?
  doctor       User?         @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: SetNull)
  caseId       String?
  clinicalCase ClinicalCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  dateTime     DateTime
  meetLink     String?
  status       String        @default("pending") // pending, confirmed, completed, cancelled
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Int           @default(0) // en créditos
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(uuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount      Int
  type        String   // in, out
  description String
  status      String   @default("completed") // pending, completed, failed
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role      String?
  action    String
  entity    String
  ip        String?
  details   Json?
  createdAt DateTime @default(now())
}

model AiProvider {
  id                 String     @id @default(uuid())
  name               String     @unique // e.g. "openai", "anthropic", "custom"
  protocol           String     // "openai", "claude", "generic"
  baseUrl            String
  modelsEndpoint     String?
  completionEndpoint String
  status             String     @default("active") // active, inactive
  priority           Int        @default(1)
  timeoutMs          Int        @default(10000)
  supportsStreaming  Boolean    @default(true)
  supportsVision     Boolean    @default(false)
  supportsTools      Boolean    @default(false)
  regionPolicy       String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  
  apiKeys            AiApiKey[]
  models             AiModel[]
}

model AiApiKey {
  id              String     @id @default(uuid())
  providerId      String
  provider        AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  label           String
  encryptedSecret String
  status          String     @default("active") // active, inactive
  rateLimit       Int?
  monthlyBudget   Float?
  createdBy       String?
  rotatedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model AiModel {
  id                     String     @id @default(uuid())
  providerId             String
  provider               AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  modelName              String
  displayName            String
  capabilities           String[]
  maxContext             Int        @default(8192)
  enabled                Boolean    @default(true)
  clinicalAllowed        Boolean    @default(false)
  costTier               String     @default("medium")
  latencyTier            String     @default("medium")
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

model RoutingPolicy {
  id                     String     @id @default(uuid())
  useCase                String     @unique
  riskLevel              String     @default("low")
  requiredCapabilities   String[]
  allowedModels          String[]
  fallbackChain          String[]
  maxCost                String     @default("medium")
  maxLatency             String     @default("medium")
  requireClinicalApproved Boolean   @default(false)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

model SubscriptionPlan {
  id              String   @id @default(uuid())
  name            String   // "Básico", "Familiar", "Premium"
  description     String
  stripePriceId   String?  // price_id de Stripe (test o producción)
  stripeProductId String?
  credits         Int      @default(0) // créditos mensuales incluidos
  price           Float    // precio en MXN (o moneda configurada)
  currency        String   @default("MXN")
  interval        String   @default("monthly") // monthly, yearly, one_time
  isActive        Boolean  @default(true)
  features        Json     @default("[]") // lista de bullets de features
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
